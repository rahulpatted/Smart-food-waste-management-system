# ============================================================================
# MongoDB Configuration
# ============================================================================
# Get your MongoDB Atlas URI from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority&appName=Cluster0

# ============================================================================
# JWT Authentication
# ============================================================================
# Generate a secure random string for production
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production!@#

# ============================================================================
# Node Environment
# ============================================================================
# Values: development, production, test
NODE_ENV=development

# ============================================================================
# Server Port (will use 5000 if not set)
# ============================================================================
PORT=5000

# ============================================================================
# AI Service URL (Auto-set by Render, use for local development)
# ============================================================================
# For local dev: http://localhost:8000
# For production: Will be auto-injected by Render
AI_SERVICE_URL=http://localhost:8000

# ============================================================================
# Frontend API URL (for CORS and cross-service communication)
# ============================================================================
# For local dev: http://localhost:3000
# For production: Will be auto-injected by Render
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Email Service (Optional - for notifications)
# ============================================================================
# Set these if you want to enable email notifications
EMAIL_SERVICE_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ============================================================================
# Database Backup (Optional)
# ============================================================================
BACKUP_ENABLED=false
BACKUP_FREQUENCY=daily

# ============================================================================
# Logging
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info
